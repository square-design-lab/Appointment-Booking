# ─── Athena API ────────────────────────────────────────────────────────────────
# Sandbox credentials — swap for production values before go-live
ATHENA_CLIENT_ID=your_client_id_here
ATHENA_CLIENT_SECRET=your_client_secret_here
ATHENA_PRACTICE_ID=your_practice_id_here
ATHENA_BASE_URL=https://api.preview.platform.athenahealth.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ─── WordPress REST API ─────────────────────────────────────────────────────────
# Used by /api/booking/provider-info to fetch provider photos and names
WP_REST_URL=https://vantagementalhealth.org/wp-json/wp/v2/providers
WP_APP_USER=your_wp_app_user
WP_APP_PASS=your_wp_app_password

# ─── Slot sync (existing booking widget) ───────────────────────────────────────
SYNC_SECRET=your_sync_secret_here
DATE_OFFSET_DAYS=1

# ─── Twilio (support alerts — optional for local dev) ──────────────────────────
# Uses API Key auth (preferred) or fall back to auth token
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
SUPPORT_PHONE=+1xxxxxxxxxx
